<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>AOOEOODialogBase</class>
 <widget class="QDialog" name="AOOEOODialogBase">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>900</width>
    <height>600</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>HELCOM AOO/EOO</string>
  </property>
  
  <layout class="QHBoxLayout" name="mainHorizontalLayout">
   <!-- LEFT PANEL: STEPS -->
   <item>
    <layout class="QVBoxLayout" name="leftPanelLayout">
	
	<item>
      <widget class="QWidget" name="big_step1">
	  <layout class="QVBoxLayout">
     <!-- STEP 1: CSV -->

        <item>
         <widget class="QLabel">
          <property name="text">
           <string>Step 1 — Select CSV file with Ecosystem components (habitats, species, communities)</string>
          </property>
          <property name="styleSheet">
           <string>font-weight: bold;</string>
          </property>
         </widget>
        </item>
        <item>
            <widget class="QLabel" name="csvLabel">
              <property name="text">
                <string>First column of CSV file should contain Ecosystem component names.</string>
              </property>
            </widget>
          </item>

          <item>
            <layout class="QHBoxLayout" name="csvInputLayout">
              <item>
                <widget class="QLineEdit" name="csvPathLineEdit"/>
              </item>
              <item>
                <widget class="QPushButton" name="btnBrowseCsv">
                  <property name="text">
                    <string>Browse…</string>
                  </property>
                </widget>
              </item>
            </layout>
          </item>


    <!-- STEP 2: EC / P selection -->
	
	  
		  <!-- Step title -->
		  <item>
			<widget class="QLabel">
			  <property name="text">
				<string>Step 2 — Select Ecosystem components for calculation</string>
			  </property>
			  <property name="styleSheet">
				<string>font-weight: bold;</string>
			  </property>
			</widget>
		  </item>

		  <!-- EC and P containers side by side -->
		  <item>
			<layout class="QHBoxLayout">

			  <!-- ================= EC SELECTION ================= -->
			  <item>
				<widget class="QGroupBox">
				 
				  <layout class="QVBoxLayout">

					<!-- Search ECs -->
					<item>
					  <widget class="QLineEdit" name="searchECLineEdit">
						<property name="placeholderText">
						  <string>Search Ecosystem components…</string>
						</property>
					  </widget>
					</item>

					<!-- Select / Deselect EC buttons -->
					<item>
					  <layout class="QHBoxLayout">
						<item>
						  <widget class="QPushButton" name="btnSelectAllECs">
							<property name="text">
							  <string>Select All</string>
							</property>
						  </widget>
						</item>
						<item>
						  <widget class="QPushButton" name="btnDeselectAllECs">
							<property name="text">
							  <string>Deselect All</string>
							</property>
						  </widget>
						</item>
					  </layout>
					</item>

					<!-- EC checkbox list -->
					<item>
					  <widget class="QScrollArea" name="ecScrollArea">
						<property name="widgetResizable">
						  <bool>true</bool>
						</property>
						<widget class="QWidget">
						  <layout class="QVBoxLayout" name="ecCheckboxLayout"/>
						</widget>
					  </widget>
					</item>

				  </layout>
				</widget>
			  </item>
			</layout>
		  </item>



     <!-- STEP 3: Confirm -->
     <item>
      
         <widget class="QPushButton" name="btnConfirmSelection">
          <property name="text">
           <string>Confirm selection</string>
          </property>
         </widget>

     </item>
	 </layout>
	 </widget>
    </item>



	<item>
      <widget class="QWidget" name="big_step2">
	  <layout class="QVBoxLayout" name="big_step2_Layout">
     <!-- RETURN BUTTON -->
       <item>
         <widget class="QPushButton" name="btnReturnToSelection">
          <property name="text">
           <string>Return to selection</string>
          </property>
         </widget>
        </item>

     <!-- STEP 4: FOLDERS -->
		  <item>
			<widget class="QLabel">
			  <property name="text">
				<string>Step 3 — Select folder with Ecosystem components distribution rasters</string>
			  </property>
			  <property name="styleSheet">
				<string>font-weight: bold;</string>
			  </property>
			</widget>
		  </item>

		  <!-- EC folder -->
		  
		  <item>
			<layout class="QHBoxLayout">
			  <item>
				<widget class="QLineEdit" name="ecFolderLineEdit"/>
			  </item>
			  <item>
				<widget class="QPushButton" name="btnBrowseECFolder">
				  <property name="text">
					<string>Browse…</string>
				  </property>
				</widget>
			  </item>
			</layout>
		  </item>

		  
     <!-- STEP 5: VALIDATE -->

        <item>
         <widget class="QPushButton" name="btnValidate">
          <property name="text">
           <string>Validate rasters</string>
          </property>
         </widget>
        </item>

	</layout>
	</widget>
    </item>



	<item>
      <widget class="QWidget" name="big_step3">
	  <layout class="QVBoxLayout" name="big_step3_Layout">
	  
	  <!-- RETURN BUTTON -->
       <item>
         <widget class="QPushButton" name="btnReturnToFolders">
          <property name="text">
           <string>Return to folder selection</string>
          </property>
         </widget>
        </item>
		
     <!-- STEP 6: OUTPUT + TOOLS -->
        <item>
         <widget class="QLabel">
          <property name="text">
           <string>Step 4 — Select output folder and processing options</string>
          </property>
          <property name="styleSheet">
           <string>font-weight: bold;</string>
          </property>
         </widget>
        </item>

        <!-- Output folder -->
		<item>
		  <widget class="QLabel">
			<property name="text">
			  <string>Select output folder:</string>
			</property>
		  </widget>
		</item>
		<item>
		  <layout class="QHBoxLayout">
			<item>
			  <widget class="QLineEdit" name="outputFolderLineEdit"/>
			</item>
			<item>
			  <widget class="QPushButton" name="btnBrowseOutputFolder">
				<property name="text">
				  <string>Browse…</string>
				</property>
			  </widget>
			</item>
		  </layout>
		</item>

        <item>
         <widget class="QGroupBox" name="toolsOptionsGroupBox">
          <property name="title">
           <string>Processing options:</string>
          </property>
          <layout class="QVBoxLayout">
           <item>
			<widget class="QCheckBox" name="chkClipCoast">
			 <property name="text">
			  <string>Clip to Baltic Sea coastline</string>
			 </property>
			 <property name="checked">
			  <bool>true</bool>
			 </property>
			</widget>
		   </item>
		   <item>
			<widget class="QCheckBox" name="chkAddToMap">
			 <property name="text">
			  <string>Add result Shapefile to the QGIS map</string>
			 </property>
			 <property name="checked">
			  <bool>true</bool>
			 </property>
		    </widget>
		   </item>
          </layout>
         </widget>
        </item>
		
		
		<!-- Add results to QGIS map -->
		


     <!-- STEP 7: RUN -->
        <item>
         <widget class="QPushButton" name="btnRunTools">
          <property name="text">
           <string>Run selected tools</string>
          </property>
         </widget>
        </item>
			 
	</layout>
	</widget>
    </item>
	
	
	
	<item>
      <widget class="QWidget" name="big_step4">
	  <layout class="QVBoxLayout" name="big_step4_Layout">
	  
	  	
     <!-- RUN PROGRESS -->
        <item>
         <widget class="QLabel">
          <property name="text">
           <string>Processing progress</string>
          </property>
          <property name="styleSheet">
           <string>font-weight: bold;</string>
          </property>
         </widget>
        </item>
		
		<!-- Estimated runtime label -->
		<item>
		  <widget class="QLabel" name="estimatedRuntimeLabel">
			<property name="text">
			  <string></string>
			</property>
			<property name="alignment">
			  <set>Qt::AlignLeft</set>
			</property>
			<property name="styleSheet">
			  <string>color: #555555; font-style: italic;</string>
			</property>
		  </widget>
		</item>

		<!-- Processing progress bar -->
		<item>
		  <widget class="QProgressBar" name="processingProgressBar">
			<property name="minimum">
			  <number>0</number>
			</property>
			<property name="maximum">
			  <number>100</number>
			</property>
			<property name="value">
			  <number>0</number>
			</property>
			<property name="textVisible">
			  <bool>true</bool>
			</property>
		  </widget>
		</item>
		
		<!-- Cancel processing -->
		<item>
		  <widget class="QPushButton" name="btnCancelProcessing">
			<property name="text">
			  <string>Cancel processing</string>
			</property>
		  </widget>
		</item>

		
		<!-- START OVER -->
        <item>
         <widget class="QPushButton" name="btnStartOver">
          <property name="text">
           <string>Start the whole processing again</string>
          </property>
         </widget>
        </item>
		
	</layout>
	</widget>
    </item>

    </layout>
   </item>

   <!-- RIGHT PANEL: SUMMARY / OUTPUT -->
   <item>
    <layout class="QVBoxLayout" name="rightPanelLayout">
	 <item>
	  <layout class="QHBoxLayout" name="topBarLayout">

		<!-- Left spacer -->
		<item>
		  <spacer name="leftSpacer">
			<property name="orientation">
			  <enum>Qt::Horizontal</enum>
			</property>
			<property name="sizeHint">
			  <size>
				<width>40</width>
				<height>20</height>
			  </size>
			</property>
		  </spacer>
		</item>

		<!-- Help button -->
		<item>
		  <widget class="QPushButton" name="btnHelp">
			<property name="text">
			  <string>Help</string>
			</property>
			<property name="toolTip">
			  <string>Open user guide</string>
			</property>
		  </widget>
		</item>

	  </layout>
	</item>
	 <item>
		<widget class="QLabel" name="statusMessageLabel">
		  <property name="text">
			<string></string>
		  </property>
		  <property name="styleSheet">
			<string notr="true">font-weight: bold; color: #333333;</string>
		  </property>
		</widget>
	 </item>
	 
     <item>
      <widget class="QLabel">
       <property name="text">
        <string>Summary and output</string>
       </property>
       <property name="styleSheet">
        <string>font-weight: bold;</string>
       </property>
      </widget>
     </item>
	 
     <item>
      <widget class="QTextEdit" name="selectionOutput">
       <property name="readOnly">
        <bool>true</bool>
       </property>
       <property name="placeholderText">
        <string>Messages, validation results and processing output will appear here…</string>
       </property>
      </widget>
     </item>
    </layout>
   </item>

  </layout>
 </widget>
</ui>
